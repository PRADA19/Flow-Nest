# Frontend Deployment Settings (Optional)
# Leave blank to automatically proxy API calls through Vercel reverse proxy (/api rewrite rules).
# If you want to configure a direct remote API backend domain (e.g. Render) without using proxying, set this value.

API_BASE=https://flownest-backend.onrender.com
VITE_API_URL=https://flownest-backend.onrender.com
NEXT_PUBLIC_API_URL=https://flownest-backend.onrender.com
