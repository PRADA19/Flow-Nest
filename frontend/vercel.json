{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://flow-nest-2.onrender.com/api/:path*"
    },
    {
      "source": "/",
      "destination": "/pages/index.html"
    },
    { "source": "/dashboard", "destination": "/pages/dashboard.html" },
    { "source": "/analytics", "destination": "/pages/analytics.html" },
    { "source": "/assistant", "destination": "/pages/assistant.html" },
    { "source": "/help", "destination": "/pages/help.html" },
    { "source": "/settings", "destination": "/pages/settings.html" },
    { "source": "/games", "destination": "/pages/games.html" },
    { "source": "/reset-password", "destination": "/pages/reset-password.html" },
    { "source": "/admin", "destination": "/pages/admin.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}