{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://flow-nest-2.onrender.com/api/:path*"
    },
    {
      "source": "/dashboard",
      "destination": "/pages/dashboard.html"
    },
    {
      "source": "/settings",
      "destination": "/pages/settings.html"
    },
    {
      "source": "/analytics",
      "destination": "/pages/analytics.html"
    },
    {
      "source": "/assistant",
      "destination": "/pages/assistant.html"
    },
    {
      "source": "/games",
      "destination": "/pages/games.html"
    },
    {
      "source": "/reset-password",
      "destination": "/pages/reset-password.html"
    },
    {
      "source": "/",
      "destination": "/pages/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}