# Server Port Configuration
PORT=5003

# MongoDB Atlas Connection URI
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/smarttodo?retryWrites=true&w=majority

# JWT Token Signing Secret (Generate a strong random string - CRITICAL: Change in production!)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_STRING_IN_PRODUCTION

# Cookie Signature Signing Secret (Generate a strong random string - CRITICAL: Change in production!)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
COOKIE_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_STRING_IN_PRODUCTION

# Production Client Frontend domain (Vercel URL)
CLIENT_URL=https://your-frontend-vercel-app.vercel.app
ALLOWED_ORIGINS=https://your-frontend-vercel-app.vercel.app

# Google Gemini API Key (Optional, powers AI Assistant features)
GEMINI_API_KEY=your-gemini-api-key-here

# Advanced Reminder Cron Secret
CRON_SECRET=your-secret-cron-token-here

# SMTP Email Settings (e.g. Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
FROM_EMAIL="FlowNest Reminders" <your-email@gmail.com>

