{
  "name": "smarttodo",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "start:server": "node server.js",
    "pm2:start": "pm2 start ecosystem.config.cjs --update-env",
    "pm2:restart": "pm2 restart smarttodo --update-env",
    "pm2:stop": "pm2 stop smarttodo",
    "pm2:delete": "pm2 delete smarttodo",
    "pm2:status": "pm2 status smarttodo",
    "pm2:logs": "pm2 logs smarttodo --lines 50",
    "pm2:save": "pm2 save"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.1.4",
    "morgan": "^1.10.1",
    "openai": "^6.39.1"
  }
}
